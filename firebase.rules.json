{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",

    "hub": {
      "calendar":  { "$id": { ".validate": "newData.hasChildren(['date','title'])" } },
      "links":     { "$id": { ".validate": "newData.hasChildren(['url','title'])" } },
      "patchNotes": { ".validate": "newData.hasChildren(['text'])" }
    },

    "painel": {
      "$dia": {
        "criacaoNoturna": {
          "done":      { "$key": { ".validate": "newData.hasChild('by')" } },
          "ids":       { "$key": { ".validate": "newData.hasChild('val')" } },
          "presence":  { "$sid": { ".validate": "newData.hasChild('name')" } }
        }
      }
    }
  }
}
